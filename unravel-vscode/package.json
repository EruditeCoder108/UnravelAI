{
    "name": "unravel-vscode",
    "displayName": "Unravel — Causal AI Debugger",
    "description": "Stop letting AI guess. Deterministic AST analysis for exact root causes and zero-hallucination fixes.",
    "version": "0.3.0",
    "publisher": "unravel",
    "icon": "icon.png",
    "license": "BUSL-1.1",
    "repository": {
        "type": "git",
        "url": "https://github.com/EruditeCoder108/UnravelAI"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Debuggers",
        "Programming Languages"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "unravel.debugFile",
                "title": "Unravel: Debug This File"
            },
            {
                "command": "unravel.explainFile",
                "title": "Unravel: Explain This File"
            },
            {
                "command": "unravel.securityFile",
                "title": "Unravel: Security Scan This File"
            },
            {
                "command": "unravel.clearDiagnostics",
                "title": "Unravel: Clear Diagnostics"
            },
            {
                "command": "unravel.initKnowledgeGraph",
                "title": "Unravel: Initialize Knowledge Graph",
                "icon": "$(symbol-namespace)"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "unravel.debugFile",
                    "when": "editorLangId == javascript || editorLangId == typescript || editorLangId == javascriptreact || editorLangId == typescriptreact",
                    "group": "unravel@1"
                },
                {
                    "command": "unravel.explainFile",
                    "when": "editorLangId == javascript || editorLangId == typescript || editorLangId == javascriptreact || editorLangId == typescriptreact || editorLangId == python || editorLangId == css || editorLangId == html",
                    "group": "unravel@2"
                },
                {
                    "command": "unravel.securityFile",
                    "when": "editorLangId == javascript || editorLangId == typescript || editorLangId == javascriptreact || editorLangId == typescriptreact || editorLangId == python",
                    "group": "unravel@3"
                }
            ]
        },
        "configuration": {
            "title": "Unravel",
            "properties": {
                "unravel.apiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Your API key for the AI provider (Gemini, Claude, or OpenAI)."
                },
                "unravel.provider": {
                    "type": "string",
                    "enum": [
                        "google",
                        "anthropic",
                        "openai"
                    ],
                    "default": "google",
                    "description": "AI provider to use for analysis."
                },
                "unravel.model": {
                    "type": "string",
                    "default": "gemini-2.5-flash",
                    "description": "Model ID to use for analysis."
                },
                "unravel.mode": {
                    "type": "string",
                    "enum": [
                        "debug",
                        "explain",
                        "security"
                    ],
                    "default": "debug",
                    "description": "Default analysis mode: debug (find bugs), explain (understand code), security (find vulnerabilities). Right-click commands override this."
                },
                "unravel.outputPreset": {
                    "type": "string",
                    "enum": [
                        "quick",
                        "developer",
                        "full"
                    ],
                    "default": "developer",
                    "description": "How much detail to include in debug reports. quick=root cause+fix only, developer=+variables+timeline, full=everything."
                },
                "unravel.level": {
                    "type": "string",
                    "enum": [
                        "beginner",
                        "intermediate",
                        "vibe"
                    ],
                    "default": "intermediate",
                    "description": "Your coding level — affects explanation depth and analogy style."
                },
                "unravel.language": {
                    "type": "string",
                    "enum": [
                        "english",
                        "hinglish",
                        "hindi"
                    ],
                    "default": "english",
                    "description": "Output language for the analysis report."
                },
                "unravel.excludeFolders": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Folder names or glob patterns to exclude from Knowledge Graph indexing (e.g. 'Understand-Anything-Clone', 'validation', 'old bugs for initial testing'). These are added on top of the default exclusions (node_modules, dist, .git, build, .next)."
                }
            }
        }
    },
    "scripts": {
        "build": "node esbuild.js",
        "watch": "node esbuild.js --watch",
        "package": "npx -y @vscode/vsce package --no-dependencies"
    },
    "devDependencies": {
        "@vscode/vsce": "^2.22.0",
        "esbuild": "^0.20.0"
    },
    "dependencies": {
        "web-tree-sitter": "^0.26.7"
    }
}
